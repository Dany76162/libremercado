# Copiá este archivo a ".env" en la raíz del repo (junto a package.json).
# Luego: pnpm run dev  (Postgres en Docker :5434, API :5000, web :3000)

DATABASE_URL=postgresql://libremercado:libremercado@127.0.0.1:5434/libremercado
SESSION_SECRET=dev-cambiar-en-produccion

# Opcional (por defecto API=5000, web=3000)
# API_PORT=5000
# WEB_PORT=3000

# Sin Replit: guardar subidas en disco (artifacts/api-server/uploads/local-gcs/…)
USE_LOCAL_UPLOADS=true

# Opcional: no tocar datos demo al arrancar
# SKIP_DEMO_UPDATE=true
