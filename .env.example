# ─── Raíz del monorepo (copiá a .env) ─────────────────────────────────────────
# Desarrollo local: docker compose + pnpm run dev

DATABASE_URL=postgresql://libremercado:libremercado@127.0.0.1:5434/libremercado
SESSION_SECRET=dev-cambiar-en-produccion

# API (Railway inyecta PORT)
# API_PORT=5000
# WEB_PORT=3000

# Subidas locales (sin R2): imágenes en disco bajo uploads/
USE_LOCAL_UPLOADS=true

# SKIP_DEMO_UPDATE=true

# ─── Backend / Railway (producción) ───────────────────────────────────────────
# URL pública del API (sin barra final). Sirve para URLs absolutas de archivos.
# API_PUBLIC_URL=https://api.tudominio.com

# PostgreSQL (Railway)
# DATABASE_URL=postgresql://...

# CORS: orígenes del front (Vercel), separados por coma, sin barra final.
# CORS_ORIGINS=https://app.tudominio.com,https://tudominio.vercel.app

# Front en dominio distinto al API: cookies de sesión cross-site (HTTPS obligatorio).
# SESSION_CROSS_SITE=true

# Stripe (secretos solo en Railway)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudflare R2 (S3-compatible). Omití si USE_LOCAL_UPLOADS=true (solo dev).
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# Opcional: endpoint custom (default https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com)
# R2_ENDPOINT=
# Público CDN/custom domain para assets (sin barra final). Si falta, se usa API_PUBLIC_URL + /api/files/...
# R2_PUBLIC_BASE_URL=https://cdn.tudominio.com

# OpenAI (rutas de generación de contenido)
# AI_INTEGRATIONS_OPENAI_API_KEY=
# AI_INTEGRATIONS_OPENAI_BASE_URL=

# Email (producción)
# SMTP_...

# ─── Frontend / Vercel ───────────────────────────────────────────────────────
# Build: definir en Vercel → Environment Variables
# VITE_API_BASE_URL=https://api.tudominio.com
# Opcional si el WS no sigue el mismo host que el API:
# VITE_WS_URL=wss://api.tudominio.com
